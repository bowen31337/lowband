<?xml version="1.0" encoding="UTF-8"?>
<!--
  LowBand Windows MSI Installer - WiX 3.x source
  ===============================================
  Designed for silent/MDM enterprise deployment:
    - No interactive UI blocks - runs fully non-interactively with /qn
    - Machine-wide installation under %ProgramFiles%\LowBand
    - lowbandd runs as a Virtual Service Account (NT SERVICE\LowBandDaemon)
      with least-privilege rights; no password management required
    - Major-upgrade removes the previous version before installing the new one

  Silent install:
    msiexec /i lowband-<version>-windows.msi /qn /norestart

  MDM deployment (Intune, SCCM/ConfigMgr, etc.):
    - Intune: upload as a "Windows app (Win32)" or Line-of-Business app.
      Install command:  msiexec /i lowband.msi /qn /norestart
      Uninstall command: msiexec /x {ProductCode} /qn /norestart
    - SCCM: add as an Application, deployment type MSI, silent flag /qn.
    - Group Policy Software Installation: place on a share, link to an OU.
    - Optionally push the companion ADMX/ADML templates (packaging\windows\mdm\)
      to configure signaling and TURN endpoints without touching the binary.

  Building (via build_msi.ps1 - do not invoke candle/light directly):
    .\packaging\windows\build_msi.ps1

  Variables injected by build_msi.ps1:
    $(var.Version)   - semver string, e.g. 1.2.3
    $(var.BinDir)    - directory containing the compiled lowbandd.exe
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <!--
    UpgradeCode: identifies this product FAMILY across all versions.
    This value MUST remain constant for major-upgrade detection to work.
    Generated once; never regenerate.
  -->
  <Product
      Id="*"
      Name="LowBand"
      Language="1033"
      Version="$(var.Version)"
      Manufacturer="LowBand Project"
      UpgradeCode="A7B3C4D5-E6F7-4A8B-9C0D-1E2F3A4B5C6D">

    <Package
        InstallerVersion="500"
        Compressed="yes"
        InstallScope="perMachine"
        Platform="x64"
        Description="LowBand P2P remote-assist client $(var.Version)"
        Manufacturer="LowBand Project"
        Comments="Silent enterprise installer - deploy via MDM or msiexec /qn"
    />

    <!-- Single embedded cabinet (no external .cab needed for distribution) -->
    <MediaTemplate EmbedCab="yes"/>

    <!--
      Major-upgrade: detect and remove the previously installed version before
      laying down the new one.  Scheduled after InstallInitialize so that a
      failed upgrade does not leave the machine unprotected.
    -->
    <MajorUpgrade
        DowngradeErrorMessage="A newer version of LowBand is already installed. Uninstall it first, or use a higher version number."
        AllowSameVersionUpgrades="no"
        Schedule="afterInstallInitialize"
    />

    <!-- ── Directory layout ───────────────────────────────────────────────── -->
    <!--
      %ProgramFiles%\LowBand\        - lowbandd.exe daemon binary
      %ProgramData%\LowBand\         - SQLite stores, audit_log
      %ProgramData%\LowBand\Logs\    - stdout/stderr log files
    -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="LowBand"/>
      </Directory>
      <Directory Id="CommonAppDataFolder">
        <Directory Id="LOWBAND_APPDATA" Name="LowBand">
          <Directory Id="LOWBAND_LOGS" Name="Logs"/>
        </Directory>
      </Directory>
    </Directory>

    <!-- ── Feature ────────────────────────────────────────────────────────── -->
    <!--
      Single feature - no optional components for MDM/silent deploy scenarios.
      All files install unconditionally at Level="1".
    -->
    <Feature Id="ProductFeature" Title="LowBand" Level="1" Absent="disallow">
      <ComponentGroupRef Id="MainComponents"/>
    </Feature>

    <!-- ── Components ─────────────────────────────────────────────────────── -->
    <ComponentGroup Id="MainComponents">

      <!--
        lowbandd.exe - core P2P remote-assist daemon.

        Runs as NT SERVICE\LowBandDaemon (a Virtual Service Account).
        Virtual service accounts:
          - Created automatically by the Service Control Manager when the service
            is first started; no explicit user creation step is required.
          - Named NT SERVICE\<ServiceName> - maps to a unique local identity.
          - Cannot be used to log on interactively or access network resources
            with their own credentials (principle of least privilege).
          - No password to rotate or manage.
      -->
      <Component Id="C_lowbandd" Directory="INSTALLFOLDER"
                 Guid="B1C2D3E4-F5A6-4B7C-8D9E-0F1A2B3C4D5E">
        <File Id="lowbandd.exe"
              Source="$(var.BinDir)\lowbandd.exe"
              KeyPath="yes"/>

        <!--
          ServiceInstall: registers lowbandd as an auto-start Win32 service.
          The Virtual Service Account (Account="NT SERVICE\LowBandDaemon")
          requires no Password attribute - the SCM manages the credential.

          Arguments map to the same IPC/data-dir layout used on macOS:
            ipc-pipe flag   local named pipe (replaces Unix socket)
            data-dir flag   ProgramData store for SQLite databases
        -->
        <ServiceInstall
            Id="lowbandd_svc"
            Name="LowBandDaemon"
            DisplayName="LowBand Remote-Assist Daemon"
            Description="Core P2P remote-assist daemon for LowBand. Handles media relay, IPC socket, and signed audit logging."
            Type="ownProcess"
            Start="auto"
            ErrorControl="normal"
            Account="NT SERVICE\LowBandDaemon"
            Arguments="--ipc-pipe \\.\pipe\lowband --data-dir &quot;[CommonAppDataFolder]LowBand&quot;"
            Interactive="no"
            Vital="yes"
        >
          <!--
            Failure actions: restart the service automatically on the first two
            crashes (mirrors macOS KeepAlive + ThrottleInterval 10).
            After the third consecutive failure, log an event but do not restart
            to avoid a tight crash loop that masks the root cause.
          -->
          <util:ServiceConfig
              FirstFailureActionType="restart"
              SecondFailureActionType="restart"
              ThirdFailureActionType="none"
              RestartServiceDelayInSeconds="10"
              ResetPeriodInDays="1"
          />
        </ServiceInstall>

        <!-- Start on install, stop on both install (upgrade) and uninstall, remove on uninstall -->
        <ServiceControl
            Id="lowbandd_svc_ctrl"
            Name="LowBandDaemon"
            Start="install"
            Stop="both"
            Remove="uninstall"
            Wait="yes"
        />
      </Component>

      <!--
        %ProgramData%\LowBand\ - daemon data directory.
        Grant the Virtual Service Account full control so it can create its
        SQLite stores and audit_log.  Administrators retain full control for
        log collection and forensic export.
      -->
      <Component Id="C_AppDataDir" Directory="LOWBAND_APPDATA"
                 Guid="C2D3E4F5-A6B7-4C8D-9E0F-1A2B3C4D5E6F">
        <CreateFolder>
          <util:PermissionEx
              User="NT SERVICE\LowBandDaemon"
              GenericAll="yes"/>
          <util:PermissionEx
              User="Administrators"
              GenericAll="yes"/>
          <util:PermissionEx
              User="SYSTEM"
              GenericAll="yes"/>
        </CreateFolder>
      </Component>

      <!--
        %ProgramData%\LowBand\Logs\ - daemon log output.
        Same ACL as the data directory; separate path keeps logs
        collectible without granting write access to the data store.
      -->
      <Component Id="C_LogDir" Directory="LOWBAND_LOGS"
                 Guid="D3E4F5A6-B7C8-4D9E-0F1A-2B3C4D5E6F7A">
        <CreateFolder>
          <util:PermissionEx
              User="NT SERVICE\LowBandDaemon"
              GenericAll="yes"/>
          <util:PermissionEx
              User="Administrators"
              GenericAll="yes"/>
          <util:PermissionEx
              User="SYSTEM"
              GenericAll="yes"/>
        </CreateFolder>
      </Component>

    </ComponentGroup>

    <!-- ── Properties ─────────────────────────────────────────────────────── -->
    <!--
      Force machine-wide installation; per-user installs are not supported
      because the Windows Service requires HKLM access and a machine-scope
      install directory under %ProgramFiles%.
    -->
    <Property Id="MSIINSTALLPERUSER" Value="0" Secure="yes"/>

    <!--
      Suppress automatic reboot prompts.  MDM tools typically schedule their
      own maintenance windows; we must not trigger surprise reboots.
      If a reboot is genuinely required (e.g. a locked file), the installer
      still records the pending reboot in the registry but does not prompt.
    -->
    <Property Id="REBOOT" Value="ReallySuppress"/>

    <!-- ── Conditions ─────────────────────────────────────────────────────── -->
    <!--
      Require 64-bit Windows 10 (build 14393) or Windows Server 2016+.
      DXGI Desktop Duplication API (used by the screen-capture backend)
      requires at least Windows 8; we enforce 10 for full SendInput/DXGI
      support and long-term supportability.
    -->
    <Condition Message="LowBand requires a 64-bit version of Windows 10 (version 1607) or Windows Server 2016 or later.">
      <![CDATA[VersionNT64 >= 603]]>
    </Condition>

    <!--
      Refuse per-user installs if someone launches the MSI with MSIINSTALLPERUSER=1.
      Machine-wide is non-negotiable for a service-based installer.
    -->
    <Condition Message="LowBand must be installed for all users (machine-wide). Run the installer as an administrator.">
      <![CDATA[MSIINSTALLPERUSER = "0" OR NOT MSIINSTALLPERUSER]]>
    </Condition>

  </Product>
</Wix>
